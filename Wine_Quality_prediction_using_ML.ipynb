    "    'chlorides': p5,\n",
    "    'free sulfur dioxide': p6,\n",
    "    'total sulfur dioxide': p7,\n",
    "    'density': p8,\n",
    "    'pH': p9,\n",
    "    'sulphates': p10,\n",
    "    'alcohol': p11\n",
    "}\n",
    "    sample_wine = np.array([[p1,p2,p3,p4,p5,p6,p7,p8,p9,p10,p11]])\n",
    "    model = joblib.load('wine_quality_model_rf.joblib')\n",
    "    result=model.predict(sample_wine)\n",
    "    print(result)\n",
    "    if result == 0:\n",
    "        Label(master, text=\"Bad Quality Wine\").grid(row=31)\n",
    "    else:\n",
    "        Label(master, text=\"Good Quality Wine\").grid(row=31)\n",
    "    \n",
    "    \n",
    "master = Tk()\n",
    "master.title(\"Wine Quality Prediction Using Machine Learning\")\n",
    "\n",
